<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="website_config_settings_view_form" model="ir.ui.view">
        <field name="name">website.config.settings.view.form.inherit.website_sale_google_analytics_4</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="website_google_analytics_4.website_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='has_google_gtag']" position="attributes">
                <attribute name="class" separator=" " add="d-none" />
            </xpath>
            <xpath expr="//div[@name='gtag_key_setting']" position="attributes">
                <attribute name="class" separator=" " add="d-none" />
            </xpath>
            <xpath expr="//div[@name='gtag_key_setting']" position="after">
                <div class="content-group">
                    <div class="alert alert-info mt8" role="alert">
                        Manage tracking tags with
                        <a type="action" name="%(website_sale_tracking_base.action_tracking_service_list)d" class="btn-link" icon="fa-arrow-right" role="button">Tracking Services</a>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

    <record id="website_cookies_consent_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.website.website_sale_google_analytics_4</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="website_cookies_consent_google.website_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='website_google_consent_setting']" position="after">
                <setting id="google_tag_serving_url_setting"
                         string="Google First-party Mode"
                         documentation="https://developers.google.com/tag-platform/tag-manager/first-party/setup-guide">
                    <div class="row mt16">
                        <label for="gtag_serving_url"/>
                        <field name="gtag_serving_url" required="1" class="mt-1 w-75"/>
                        <div class="oe_inline">
                            <button type="object" name="action_restore_google_tag_serving_url" class="btn-sm btn-secondary" icon="fa-refresh" confirm="Set the default Google Tag Serving URL?" title="Restore the default Google Tag Serving URL"/>
                        </div>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>

</odoo>
