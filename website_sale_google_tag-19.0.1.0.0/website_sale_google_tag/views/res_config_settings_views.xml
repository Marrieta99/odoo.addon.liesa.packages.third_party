<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="website_config_settings_view_form" model="ir.ui.view">
        <field name="name">website.config.settings.view.form.inherit.website_sale_google_tag</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="website_google_tag.website_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='google_tag_manager_setting']/field" position="attributes">
                <attribute name="class" separator=" " add="d-none" />
            </xpath>
            <xpath expr="//div[@name='gtm_key_setting']" position="attributes">
                <attribute name="class" separator=" " add="d-none" />
            </xpath>
            <xpath expr="//div[@name='gtm_key_setting']" position="after">
                <div class="content-group">
                    <div class="alert alert-info mt8" role="alert">
                        Manage tracking tags with
                        <a type="action" name="%(website_sale_tracking_base.action_tracking_service_list)d" class="btn-link" icon="fa-arrow-right" role="button">Tracking Services</a>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

</odoo>
